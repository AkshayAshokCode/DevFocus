<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.akshayashokcode.devfocus</id>
    <name>DevFocus</name>
    <vendor email="akshayashokan1054@gmail.com"
            url="https://github.com/akshayashokcode"
    >akshayashokcode</vendor>
    <description>
        <![CDATA[
        DevFocus is a Pomodoro timer for Android Studio & IntelliJ
        that helps developers maintain deep focus using structured
        work sessions, breaks, and productivity tracking.
        ]]>
    </description>

    <change-notes>
        Improved session timer and enhanced UX.
    </change-notes>

    <idea-version since-build="233"/>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.akshayashokcode.devfocus.toolWindow.DevFocusToolWindowFactory"
                    id="DevFocus"
                    icon="/icons/startTimer.svg"
        />
        <projectService serviceImplementation="com.github.akshayashokcode.devfocus.services.pomodoro.PomodoroTimerService"/>
        <notificationGroup id="DevFocus Notifications" displayType="BALLOON"/>
        <statusBarWidgetFactory id="DevFocusStatusBarWidget"
                                implementation="com.github.akshayashokcode.devfocus.statusbar.PomodoroStatusBarWidgetFactory"/>
    </extensions>

    <actions>
        <group id="DevFocus.ActionGroup" text="DevFocus" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="DevFocus.Toggle"
                    class="com.github.akshayashokcode.devfocus.actions.DevFocusToggleAction"
                    text="Start / Pause Timer"
                    description="Start the DevFocus timer, or pause it if already running"/>

            <action id="DevFocus.Reset"
                    class="com.github.akshayashokcode.devfocus.actions.DevFocusResetAction"
                    text="Reset Timer"
                    description="Reset the DevFocus timer to the start of the current round"/>

            <action id="DevFocus.SkipBreak"
                    class="com.github.akshayashokcode.devfocus.actions.DevFocusSkipBreakAction"
                    text="Skip Break"
                    description="Skip the current break and start the next work session immediately"/>
        </group>
    </actions>
</idea-plugin>
